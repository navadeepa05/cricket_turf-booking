<!-- navbar.ejs -->
<nav class="navbar">
  <a href="/" class="navbar-brand">🏏 Cricket Turf</a>
  <div class="navbar-links">
    <% if (user) { %>
      <% if (user.role === 'admin') { %>
        <a href="/admin/dashboard" class="nav-link">Dashboard</a>
        <a href="/admin/bookings"  class="nav-link">Bookings</a>
        <a href="/admin/payments"  class="nav-link">Payments</a>
        <a href="/admin/customers" class="nav-link">Customers</a>
        <a href="/admin/slots"     class="nav-link">Slots</a>
      <% } else { %>
        <a href="/"          class="nav-link">Home</a>
        <a href="/book"      class="nav-link">Book Now</a>
        <a href="/bookings"  class="nav-link">My Bookings</a>
      <% } %>
      <span class="nav-user">👤 <%= user.name %></span>
      <a href="/logout" class="nav-logout">Logout</a>
    <% } else { %>
      <a href="/login" class="nav-link">Login</a>
    <% } %>
  </div>
</nav>
