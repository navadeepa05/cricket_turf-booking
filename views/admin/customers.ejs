<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Customers – Admin</title>
  <link rel="stylesheet" href="/css/style.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
</head>
<body class="admin-body">
  <%- include('../partials/navbar') %>
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="sidebar-title">Admin Panel</div>
      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="sidebar-link">🏠 Dashboard</a>
        <a href="/admin/bookings"  class="sidebar-link">📋 Bookings</a>
        <a href="/admin/payments"  class="sidebar-link">💰 Payments</a>
        <a href="/admin/customers" class="sidebar-link active">👥 Customers</a>
        <a href="/admin/slots"     class="sidebar-link">⏰ Manage Slots</a>
        <a href="/logout"          class="sidebar-link sidebar-logout">🚪 Logout</a>
      </nav>
    </aside>
    <main class="admin-main">
      <div class="admin-page-header">
        <h1>👥 Registered Customers</h1>
        <p><%= customers.length %> customer(s) registered</p>
      </div>

      <% if (customers.length === 0) { %>
        <div class="empty-state"><p>No customers registered yet.</p></div>
      <% } else { %>
        <div class="table-wrapper">
          <table class="data-table">
            <thead>
              <tr><th>#</th><th>Name</th><th>Mobile</th><th>Registered On</th><th>Total Bookings</th></tr>
            </thead>
            <tbody>
              <% customers.forEach(function(c, i) { %>
                <tr>
                  <td><%= i + 1 %></td>
                  <td>👤 <%= c.name %></td>
                  <td><%= c.mobile %></td>
                  <td><%= new Date(c.firstBookingAt).toLocaleDateString('en-IN') %></td>
                  <td><span class="badge badge-confirmed"><%= c.bookingCount %> booking(s)</span></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </main>
  </div>
</body>
</html>
